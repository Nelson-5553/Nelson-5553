---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Nelson" lang="en">
  <main class="maintenance-container">
    <div class="content-wrapper">
      <div class="icon-container">
        <svg class="code-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
        </svg>
      </div>
      
      <h1 class="title">Hello! 👋</h1>
      
      <div class="message-box">
        <p class="main-message">
          I'm currently redesigning my portfolio to showcase my projects and experience in a more comprehensive way.
        </p>
        <p class="sub-message">
          In the meantime, I'm working on new projects and improving my skills as a developer.
        </p>
      </div>

      <div class="status-indicator">
        <span class="pulse"></span>
        <span class="status-text">Developing...</span>
      </div>
    </div>
  </main>
</Layout>

<style>
  .maintenance-container {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    padding: 2rem;
  }

  .content-wrapper {
    max-width: 600px;
    text-align: center;
    background: rgba(255, 255, 255, 0.95);
    border-radius: 20px;
    padding: 3rem 2rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    animation: fadeInUp 0.8s ease-out;
  }

  .icon-container {
    margin-bottom: 2rem;
  }

  .code-icon {
    width: 80px;
    height: 80px;
    color: #667eea;
    animation: float 3s ease-in-out infinite;
  }

  .title {
    font-size: 2.5rem;
    font-weight: 700;
    color: #2d3748;
    margin-bottom: 1.5rem;
    letter-spacing: -0.5px;
  }

  .message-box {
    margin: 2rem 0;
  }

  .main-message {
    font-size: 1.2rem;
    color: #4a5568;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .sub-message {
    font-size: 1rem;
    color: #718096;
    line-height: 1.6;
  }

  .status-indicator {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid #e2e8f0;
  }

  .pulse {
    width: 12px;
    height: 12px;
    background: #48bb78;
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  .status-text {
    font-size: 0.95rem;
    color: #48bb78;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.5;
      transform: scale(1.3);
    }
  }

  @media (max-width: 640px) {
    .title {
      font-size: 2rem;
    }

    .main-message {
      font-size: 1.1rem;
    }

    .content-wrapper {
      padding: 2rem 1.5rem;
    }
  }
</style>
